<sem_type>string</sem_type>
</parameter>
<parameter id="GenParamValue">
<default_type>integer</default_type>
<sem_type>string</sem_type>
<type_list>
<item>integer</item>
<item>real</item>
</type_list>
</parameter>
<parameter id="Information">
<sem_type>string</sem_type>
</parameter>
<parameter id="Labels">
<multivalue>optional</multivalue>
